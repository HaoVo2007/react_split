# Environment Variables Example
# Copy this file to .env.local for local development

# ============================================
# API Configuration (Required)
# ============================================
# Base URL for API requests
# Local development: http://localhost:8080/api/v1
# Production: https://your-api-domain.com/api/v1
VITE_API_URL=http://localhost:8080/api/v1

# ============================================
# Frontend Configuration (Required)
# ============================================
# Frontend domain - used for preset image URLs
# Local development: http://localhost:5173
# Production: https://your-domain.vercel.app
VITE_FE_DOMAIN=http://localhost:5173

# ============================================
# App Configuration (Optional)
# ============================================
# Application name displayed in UI
VITE_APP_NAME=TravelSplit

# Environment name: local, development, production, test
VITE_APP_ENV=local

# ============================================
# Feature Flags (Optional)
# ============================================
# Enable debug logging and console messages
VITE_ENABLE_DEBUG=true

# ============================================
# NOTES
# ============================================
# 1. All variables must be prefixed with VITE_ to be accessible in Vite
# 2. Restart the dev server after changing .env files
# 3. .env files should NOT be committed to git (except .env.example)
# 4. For production, set variables in your hosting platform instead
